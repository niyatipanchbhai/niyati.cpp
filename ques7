#include <iostream>
using namespace std;

class Swap 
{
public:
    int a, b;

    void swap() 
    {
        int temp = a;
        a = b;
        b = temp;
    }
};
int main() 
{
    Swap s;
    cout << "Enter two numbers: ";
    cin >> s.a >> s.b;

    s.swap();
    cout << "After swapping: " << s.a << " " << s.b;

    return 0;
}
