#include <iostream>
using namespace std;
class Student 
{
public:
    int roll;
    string name;
};
int main() 
{
    Student s[10];

    for (int i = 0; i < 10; i++) 
    {
        cout << "Enter roll and name: ";
        cin >> s[i].roll >> s[i].name;
    }
    cout << "\nStudent Records:\n";
    for (int i = 0; i < 10; i++) 
    {
        cout << s[i].roll << " " << s[i].name << endl;
    }
    return 0;
}
