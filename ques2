#include <iostream>
using namespace std;

int main() 
{
    int number, i;
    bool prime = true;
    cout << "Enter a number: ";
    cin >> number;
    if (number <= 1)
        prime = false;

    for (i = 2; i <= number / 2; i++) 
    {
        if (number % i == 0) 
        {
            prime = true;
            break;
        }
    }
    if (prime)
        cout << "Prime Number";
    else
        cout << "Not a Prime Number";

    return 0;
}
