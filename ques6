#include <iostream>
using namespace std;
class Prime 
{
public:
    int n;

    void check() 
    {
        bool prime = true;
        if (n <= 1) prime = false;

        for (int i = 2; i <= n / 2; i++) 
        {
            if (n % i == 0) {
                prime = false;
                break;
            }
        }
        if (prime)
            cout << "Prime Number";
        else
            cout << "Not a Prime Number";
    }
};
int main() 
{
    Prime p;
    cout << "Enter number: ";
    cin >> p.n;
    p.check();
    return 0;
}
